# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://predictotron:password@localhost:5432/predictotron

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ─── Ingestion Pipeline ──────────────────────────────────────────────────────
INGEST_BATCH_SIZE=10000      # rows per DB batch insert
INGEST_CONCURRENCY=4         # parallel market fetches

# ─── WebSocket ───────────────────────────────────────────────────────────────
WS_CHANNEL=market_updates    # Redis pub/sub channel name
